enum log_source_type {
  agent_syslog
  agent_journald
  agent_windows_event
  agent_file
  docker_container
  nginx_access
  nginx_error
  application
  snmp_trap
  api_webhook
}

enum log_level {
  emergency
  alert
  critical
  error
  warning
  notice
  info
  debug
}

model ict_monitor_log_source {
  id               String          @id @default(uuid())
  company_id       String
  code             String
  name             String
  source_type      log_source_type
  config           Json?
  retention_days   Int             @default(90)
  is_enabled       Boolean         @default(true)
  last_received_at DateTime?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @default(now())
  entries          ict_monitor_log_entry[]
  decoders         ict_monitor_log_decoder[]
  rules            ict_monitor_log_rule[]
  queries          ict_monitor_log_saved_query[]

  @@unique([company_id, code])
  @@index([company_id])
  @@index([source_type])
}

model ict_monitor_log_entry {
  id              String                  @id @default(uuid())
  company_id      String
  source_id       String
  agent_id        String?
  hostname        String
  program         String?
  pid             Int?
  level           log_level               @default(info)
  message         String
  fields          Json?
  raw_log         String?
  checksum        String?
  decoded         Boolean                 @default(false)
  rule_id         String?
  alert_id        String?
  received_at     DateTime                @default(now())
  source          ict_monitor_log_source  @relation(fields: [source_id], references: [id])
  agent           ict_monitor_agent?      @relation(fields: [agent_id], references: [id])
  matched_rule    ict_monitor_log_rule?   @relation(fields: [rule_id], references: [id])

  @@index([source_id, received_at])
  @@index([company_id, received_at])
  @@index([agent_id])
  @@index([level])
  @@index([hostname])
  @@index([program])
  @@index([rule_id])
  @@index([received_at])
}

model ict_monitor_log_decoder {
  id             String                  @id @default(uuid())
  source_id      String
  company_id     String
  name           String
  description    String?
  regex_pattern  String
  extract_fields Json?
  prematch       String?
  order          Int                     @default(0)
  is_enabled     Boolean                 @default(true)
  created_at     DateTime                @default(now())
  updated_at     DateTime                @default(now())
  source         ict_monitor_log_source  @relation(fields: [source_id], references: [id])

  @@index([source_id])
  @@index([company_id])
}

model ict_monitor_log_rule {
  id                 String                   @id @default(uuid())
  source_id          String?
  company_id         String
  code               String
  name               String
  description        String?
  condition_query    Json
  action             String                   @default("alert")
  level              severity_level           @default(low)
  frequency          Int                      @default(1)
  timeframe_minutes  Int                      @default(5)
  mitre_tactic       String?
  mitre_technique    String?
  mitre_technique_id String?
  is_enabled         Boolean                  @default(true)
  created_at         DateTime                 @default(now())
  updated_at         DateTime                 @default(now())
  source             ict_monitor_log_source?  @relation(fields: [source_id], references: [id])
  matched_entries    ict_monitor_log_entry[]

  @@unique([company_id, code])
  @@index([company_id])
  @@index([source_id])
  @@index([level])
  @@index([is_enabled])
}

model ict_monitor_log_saved_query {
  id          String                  @id @default(uuid())
  source_id   String
  company_id  String
  name        String
  query       Json
  description String?
  is_shared   Boolean                 @default(false)
  created_by  String
  created_at  DateTime                @default(now())
  updated_at  DateTime                @default(now())
  source      ict_monitor_log_source  @relation(fields: [source_id], references: [id])

  @@index([source_id])
  @@index([company_id])
}

model ict_monitor_container_log {
  id           String               @id @default(uuid())
  company_id   String
  host_id      String
  container_id String
  stream       String               @default("stdout")
  line_number  Int?
  message      String
  timestamp    DateTime             @default(now())

  @@index([container_id, timestamp])
  @@index([host_id, timestamp])
  @@index([company_id, timestamp])
  @@index([timestamp])
}

enum invoice_status {
  draft
  submitted
  approved
  rejected
  paid
  overdue
  cancelled
}

enum billing_priority {
  low
  medium
  high
  urgent
}

model ict_bill_vendor {
  id             String             @id @default(uuid())
  company_id     String
  code           String
  name           String
  contact_person String?
  email          String?
  phone          String?
  address        String?
  payment_terms  String?
  is_active      Boolean            @default(true)
  created_at     DateTime           @default(now())
  updated_at     DateTime           @default(now())
  invoices       ict_bill_invoice[]

  @@unique([company_id, code])
  @@index([company_id])
}

model ict_bill_category {
  id          String              @id @default(uuid())
  company_id  String
  parent_id   String?
  code        String
  name        String
  description String?
  gl_account  String?
  budget_code String?
  is_active   Boolean             @default(true)
  created_at  DateTime            @default(now())
  updated_at  DateTime            @default(now())
  parent      ict_bill_category?  @relation("bill_category_hierarchy", fields: [parent_id], references: [id])
  children    ict_bill_category[] @relation("bill_category_hierarchy")
  invoices    ict_bill_invoice[]

  @@unique([company_id, code])
  @@index([company_id])
}

model ict_bill_invoice {
  id                String                  @id @default(uuid())
  company_id        String
  vendor_id         String
  category_id       String
  location_id       String?
  sr_request_id     String?
  code              String
  vendor_invoice_no String?
  title             String
  description       String?
  invoice_date      DateTime
  due_date          DateTime
  total_amount      Decimal
  currency          String                  @default("IDR")
  status            invoice_status          @default(draft)
  priority          billing_priority        @default(medium)
  approved_by       String?
  approved_at       DateTime?
  reject_reason     String?
  paid_at           DateTime?
  notes             String?
  tags              String[]
  metadata          Json?
  created_by        String
  created_at        DateTime                @default(now())
  updated_at        DateTime                @default(now())
  vendor            ict_bill_vendor         @relation(fields: [vendor_id], references: [id])
  category          ict_bill_category       @relation(fields: [category_id], references: [id])
  items             ict_bill_invoice_item[]

  @@unique([company_id, code])
  @@index([company_id])
  @@index([vendor_id])
  @@index([status])
  @@index([due_date])
}

model ict_bill_invoice_item {
  id          String           @id @default(uuid())
  invoice_id  String
  description String
  quantity    Decimal          @default(1)
  unit_price  Decimal
  amount      Decimal
  sort_order  Int              @default(0)
  created_at  DateTime         @default(now())
  invoice     ict_bill_invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([invoice_id])
}

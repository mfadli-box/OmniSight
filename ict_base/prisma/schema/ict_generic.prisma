enum severity_level {
  critical
  high
  medium
  low
  info
}

enum approval_status {
  pending
  approved
  rejected
}

model ict_audit_trail {
  id             String   @id @default(uuid())
  company_id     String
  entity_type    String
  entity_id      String
  user_id        String
  action         String
  old_value      String?
  new_value      String?
  note           String?
  attachment_url String?
  created_at     DateTime @default(now())

  @@index([company_id, entity_type, entity_id])
  @@index([user_id])
  @@index([created_at])
}

model ict_file_attachment {
  id          String   @id @default(uuid())
  company_id  String
  entity_type String
  entity_id   String
  file_name   String
  file_path   String
  file_size   Int
  file_type   String
  file_hash   String?
  description String?
  is_original Boolean  @default(true)
  upload_type String?
  uploaded_by String
  created_at  DateTime @default(now())

  @@index([company_id, entity_type, entity_id])
  @@index([file_hash])
  @@index([uploaded_by])
}

model ict_approval {
  id          String          @id @default(uuid())
  company_id  String
  entity_type String
  entity_id   String
  step        Int
  approver_id String
  status      approval_status @default(pending)
  comment     String?
  acted_at    DateTime?
  created_at  DateTime        @default(now())

  @@unique([entity_type, entity_id, step])
  @@index([approver_id])
  @@index([status])
}

model ict_notification {
  id          String    @id @default(uuid())
  company_id  String
  entity_type String
  entity_id   String
  user_id     String
  type        String
  message     String
  is_read     Boolean   @default(false)
  sent_at     DateTime  @default(now())
  read_at     DateTime?

  @@index([user_id])
  @@index([company_id, entity_type, entity_id])
  @@index([is_read])
}
